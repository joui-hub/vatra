---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/', label: 'Acasă' },
  { href: '/meniu', label: 'Meniu' },
  { href: '/rezervari', label: 'Rezervări' },
  { href: '/despre', label: 'Despre noi' },
];
---

<footer class="footer" role="contentinfo">
  <div class="footer__container">
    <div class="footer__grid">
      <div class="footer__col footer__col--about">
        <span class="footer__logo">Vatra</span>
        <p class="footer__desc">
          Un restaurant românesc modern unde tradiția întâlnește rafinamentul.
          Fiecare preparat spune o poveste, fiecare masă este o experiență.
        </p>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">Navigare</h4>
        <ul class="footer__links">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">Contact</h4>
        <address class="footer__address">
          <p>Str. Mihai Eminescu, Nr. 24</p>
          <p>București, România</p>
          <p class="footer__contact-line">
            <a href="tel:+40721234567">+40 721 234 567</a>
          </p>
          <p class="footer__contact-line">
            <a href="mailto:contact@vatra-restaurant.ro">contact@vatra-restaurant.ro</a>
          </p>
        </address>
        <div class="footer__hours">
          <p><strong>Program:</strong></p>
          <p>Luni - Vineri: 12:00 - 23:00</p>
          <p>Sâmbătă - Duminică: 11:00 - 00:00</p>
        </div>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">Newsletter</h4>
        <p class="footer__newsletter-text">
          Abonează-te pentru a fi la curent cu evenimentele și ofertele speciale.
        </p>
        <form class="footer__form" data-netlify="true" name="newsletter" method="POST">
          <input type="hidden" name="form-name" value="newsletter" />
          <div class="footer__form-group">
            <input
              type="email"
              name="email"
              placeholder="Email-ul tău"
              required
              aria-label="Adresa de email pentru newsletter"
              class="footer__input"
            />
            <button type="submit" class="footer__submit" aria-label="Abonează-te">→</button>
          </div>
        </form>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">
        © {currentYear} Vatra. Toate drepturile rezervate.
      </p>
      <div class="footer__social">
        <a href="#" class="footer__social-link" aria-label="Facebook">FB</a>
        <a href="#" class="footer__social-link" aria-label="Instagram">IG</a>
        <a href="#" class="footer__social-link" aria-label="TikTok">TK</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
  }

  .footer__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding-left: var(--container-pad);
    padding-right: var(--container-pad);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    margin-bottom: var(--space-12);
  }

  .footer__logo {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-gold);
    display: block;
    margin-bottom: var(--space-4);
  }

  .footer__desc {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.7;
    max-width: 300px;
  }

  .footer__heading {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__link {
    color: var(--color-muted);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer__link:hover {
    color: var(--color-text);
  }

  .footer__address {
    font-style: normal;
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.8;
  }

  .footer__contact-line {
    margin-top: var(--space-2);
  }

  .footer__contact-line a {
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer__contact-line a:hover {
    color: var(--color-accent);
  }

  .footer__hours {
    margin-top: var(--space-4);
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.8;
  }

  .footer__hours strong {
    color: var(--color-text);
  }

  .footer__newsletter-text {
    color: var(--color-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .footer__form-group {
    display: flex;
    gap: 0;
  }

  .footer__input {
    flex: 1;
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-right: none;
    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
    color: var(--color-text);
    font-size: var(--text-sm);
    outline: none;
    transition: border-color var(--transition);
  }

  .footer__input::placeholder {
    color: var(--color-muted);
  }

  .footer__input:focus {
    border-color: var(--color-accent);
  }

  .footer__submit {
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--color-bg);
    font-size: var(--text-lg);
    cursor: pointer;
    transition: background-color var(--transition);
  }

  .footer__submit:hover {
    background-color: var(--color-gold);
    border-color: var(--color-gold);
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .footer__copyright {
    color: var(--color-muted);
    font-size: var(--text-xs);
  }

  .footer__social {
    display: flex;
    gap: var(--space-4);
  }

  .footer__social-link {
    color: var(--color-muted);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: color var(--transition);
    letter-spacing: 0.05em;
  }

  .footer__social-link:hover {
    color: var(--color-accent);
  }

  @media (min-width: 640px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer__grid {
      grid-template-columns: 1.5fr 1fr 1.2fr 1.2fr;
    }

    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>

---
interface Props {
  name: string;
  role: string;
  text: string;
}

const { name, role, text } = Astro.props;
---

<article class="testimonial-card fade-in">
  <div class="testimonial-card__quote" aria-hidden="true">"</div>
  <p class="testimonial-card__text">{text}</p>
  <footer class="testimonial-card__footer">
    <div class="testimonial-card__avatar gradient-avatar"></div>
    <div>
      <p class="testimonial-card__name">{name}</p>
      <p class="testimonial-card__role">{role}</p>
    </div>
  </footer>
</article>

<style>
  .testimonial-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
  }

  .testimonial-card__quote {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: var(--space-4);
    opacity: 0.6;
  }

  .testimonial-card__text {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.8;
    flex: 1;
    margin-bottom: var(--space-6);
    font-style: italic;
  }

  .testimonial-card__footer {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .testimonial-card__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .testimonial-card__name {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
  }

  .testimonial-card__role {
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>

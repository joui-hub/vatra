---
---

<section class="contact-info" aria-label="Informații de contact">
  <h2 class="contact-info__title">Unde ne găsești</h2>

  <div class="contact-info__details">
    <div class="contact-info__item">
      <span class="contact-info__icon" aria-hidden="true">📍</span>
      <div>
        <p class="contact-info__label">Adresă</p>
        <p class="contact-info__value">Str. Mihai Eminescu, Nr. 24<br />București, România</p>
      </div>
    </div>

    <div class="contact-info__item">
      <span class="contact-info__icon" aria-hidden="true">📞</span>
      <div>
        <p class="contact-info__label">Telefon</p>
        <a href="tel:+40721234567" class="contact-info__value contact-info__link">+40 721 234 567</a>
      </div>
    </div>

    <div class="contact-info__item">
      <span class="contact-info__icon" aria-hidden="true">✉️</span>
      <div>
        <p class="contact-info__label">Email</p>
        <a href="mailto:contact@vatra-restaurant.ro" class="contact-info__value contact-info__link">contact@vatra-restaurant.ro</a>
      </div>
    </div>

    <div class="contact-info__item">
      <span class="contact-info__icon" aria-hidden="true">🕐</span>
      <div>
        <p class="contact-info__label">Program</p>
        <p class="contact-info__value">
          Luni - Vineri: 12:00 - 23:00<br />
          Sâmbătă - Duminică: 11:00 - 00:00
        </p>
      </div>
    </div>
  </div>

  <div class="contact-info__map gradient-map" role="img" aria-label="Harta locației restaurantului Vatra">
    <div class="contact-info__map-overlay">
      <span class="contact-info__map-text">Str. Mihai Eminescu, Nr. 24, București</span>
    </div>
  </div>
</section>

<style>
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .contact-info__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
  }

  .contact-info__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .contact-info__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .contact-info__icon {
    font-size: var(--text-xl);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .contact-info__label {
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-1);
  }

  .contact-info__value {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    font-style: normal;
  }

  .contact-info__link {
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .contact-info__link:hover {
    color: var(--color-accent);
  }

  .contact-info__map {
    border-radius: var(--radius-md);
    height: 250px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-info__map-overlay {
    text-align: center;
  }

  .contact-info__map-text {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-text);
    opacity: 0.8;
  }
</style>

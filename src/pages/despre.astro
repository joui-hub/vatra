---
import BaseLayout from '../layouts/BaseLayout.astro';
import TeamSection from '../components/TeamSection.astro';
import Gallery from '../components/Gallery.astro';
---

<BaseLayout title="Despre noi — Vatra Restaurant" description="Descoperă povestea Vatra, valorile echipei noastre și pasiunea pentru bucătăria românească autentică.">
  <section class="despre-hero" aria-label="Despre noi">
    <div class="despre-hero__content container">
      <span class="section__label">Despre noi</span>
      <h1 class="despre-hero__title">Rădăcini și rafinament</h1>
      <p class="despre-hero__subtitle">
        Povestea unui restaurant care celebrează tradiția culinară românească
      </p>
    </div>
  </section>

  <section class="despre-story section" aria-label="Povestea noastră">
    <div class="despre-story__container container">
      <div class="despre-story__content fade-in">
        <h2 class="despre-story__heading">Cum a început totul</h2>
        <p>
          Vatra s-a născut în 2018 dintr-un vis simplu: de a readuce în farfurie gusturile
          autentice ale României. Fondatorul nostru, Andrei Popescu, a crescut într-un sat
          din Ardeal, unde bunica lui gătea cu ingrediente din grădina proprie și unde
          fiecare masă era un prilej de bucurie și comuniune.
        </p>
        <p>
          După ani de experiență în bucătării de top din Europa, Andrei a decis să se
          întoarcă la rădăcini și să creeze un loc unde tradiția nu este doar păstrată,
          ci celebrată și reinventată. Astfel s-a născut Vatra — un spațiu unde fiecare
          preparat spune o poveste.
        </p>
        <p>
          Colaborăm cu producători locali din toată țara: brânză de la stânele din
          Transilvania, pește din Delta Dunării, legume din grădinile din jurul Bucureștiului.
          Fiecare ingredient este ales cu grijă pentru a reda autenticitatea gustului românesc.
        </p>
      </div>
      <div class="despre-story__image fade-in gradient-2" role="img" aria-label="Bucătarul pregătind un preparat tradițional"></div>
    </div>
  </section>

  <section class="despre-values section" aria-label="Valorile noastre">
    <div class="container text-center">
      <span class="section__label fade-in">Valorile noastre</span>
      <h2 class="section__title fade-in">Ce ne ghidează</h2>
    </div>
    <div class="despre-values__grid container">
      <article class="despre-values__card fade-in">
        <h3 class="despre-values__title">Autenticitate</h3>
        <p class="despre-values__text">
          Respectăm rețetele tradiționale și le transmitem mai departe, adaptându-le
          cu delicatețe la gusturile contemporane.
        </p>
      </article>
      <article class="despre-values__card fade-in">
        <h3 class="despre-values__title">Ingrediente locale</h3>
        <p class="despre-values__text">
          Lucrăm exclusiv cu producători români, susținând agricultura locală și
          asigurând prospețimea fiecărui ingredient.
        </p>
      </article>
      <article class="despre-values__card fade-in">
        <h3 class="despre-values__title">Ospitalitate</h3>
        <p class="despre-values__text">
          Fiecare oaspete este primit ca acasă. Căldura și atenția la detalii definesc
          experiența Vatra.
        </p>
      </article>
    </div>
  </section>

  <TeamSection />
  <Gallery />
</BaseLayout>

<style>
  .despre-hero {
    padding-top: 140px;
    padding-bottom: var(--space-12);
    text-align: center;
    background: linear-gradient(180deg, var(--color-surface), var(--color-bg));
  }

  .despre-hero__title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .despre-hero__subtitle {
    color: var(--color-muted);
    font-size: var(--text-lg);
    max-width: 500px;
    margin: 0 auto;
  }

  .despre-story__container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .despre-story__heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
  }

  .despre-story__content p {
    color: var(--color-muted);
    line-height: 1.8;
    margin-bottom: var(--space-4);
  }

  .despre-story__image {
    height: 400px;
    border-radius: var(--radius-lg);
  }

  .despre-values__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-top: var(--space-12);
  }

  .despre-values__card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    text-align: center;
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .despre-values__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
  }

  .despre-values__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
    color: var(--color-accent);
  }

  .despre-values__text {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.7;
    margin: 0;
  }

  @media (min-width: 640px) {
    .despre-values__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .despre-story__container {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
    }

    .despre-story__image {
      height: 500px;
      order: 1;
    }

    .despre-story__content {
      order: 0;
    }

    .despre-values__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
